# earworm secrets — copy to .env and fill in. .env is gitignored.
#
# In local dev (dotnet run), Program.cs loads this file from CWD at startup.
# In Docker, docker-compose.yml reads .env for variable substitution and
# passes the values to the container as real env vars — the .env file itself
# is never copied into the image (.dockerignore excludes it).
#
# Real environment variables always win over values in this file, so you can
# override per-shell with `set -x` (fish) or `export` (bash) without editing.

EARWORM_DISCORD_BOT_TOKEN=
EARWORM_GEMINI_API_KEY=
EARWORM_ELEVENLABS_API_KEY=

# Lavalink server password. Used by both the Lavalink container (read from
# LAVALINK_SERVER_PASSWORD inside the container) and the bot (passed through
# as EARWORM_Lavalink__Password). For local-dev against a manually-started
# Lavalink instance, leave this as "youshallnotpass" to match the default.
LAVALINK_PASSWORD=youshallnotpass

# Optional overrides
# EARWORM_LOG_LEVEL=Information
# EARWORM_METRICS_ENABLED=false
# TZ=UTC
